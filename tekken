function updateClock(){
  const now=new Date();
  const w=['日','月','火','水','木','金','土'][now.getDay()];
  document.getElementById('js-date').textContent=`${now.getFullYear()}年${p2(now.getMonth()+1)}月${p2(now.getDate())}日（${w}）`;
  document.getElementById('js-time').textContent=`${p2(now.getHours())}:${p2(now.getMinutes())}`;
