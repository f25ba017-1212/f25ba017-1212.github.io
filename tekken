/* テキスト翻訳（MyMemory API） */
async function doTranslate(){
  const src=document.getElementById('trans-src').value.trim();
  if(!src){alert('翻訳するテキストを入力してください');return;}
  const targetLang=document.getElementById('trans-lang-sel').value;
  const dst=document.getElementById('trans-dst');
  dst.value='翻訳中…';
  const langPair=`ja|${targetLang}`;
  try{
    const url=`https://api.mymemory.translated.net/get?q=${encodeURIComponent(src)}&langpair=${langPair}`;
    const res=await fetch(url);
    const json=await res.json();
    if(json.responseStatus===200){
      dst.value=json.responseData.translatedText;
    }else{
      dst.value='翻訳できませんでした。Google翻訳をお試しください。';
    }
  }catch(e){
    dst.value='ネットワークエラー。Google翻訳をお試しください。';
  }
}

