function p2(n){return String(n).padStart(2,'0');}
updateClock();setInterval(updateClock,1000);

/* =====================================================
   WEATHER — Open-Meteo（無料・登録不要）
   ===================================================== */
const WX_CODES={0:'☀️ 快晴',1:'🌤️ 晴れ',2:'⛅ 曇り',3:'☁️ 曇天',45:'🌫️ 霧',48:'🌫️ 霧',51:'🌦️ 霧雨',53:'🌦️ 霧雨',55:'🌦️ 霧雨',61:'🌧️ 小雨',63:'🌧️ 雨',65:'🌧️ 大雨',71:'❄️ 小雪',73:'❄️ 雪',75:'❄️ 大雪',80:'🌧️ にわか雨',81:'🌧️ にわか雨',82:'⛈️ 激しい雨',95:'⛈️ 雷雨',99:'⛈️ 雷雨'};
// 高崎市の座標（工場の実際の位置に変更可能）
const SITE_LAT=36.3219,SITE_LON=139.0033,SITE_NAME='高崎市（群馬）';

function wbgtFromTempHum(t,h){
  // 簡易WBGT推定式（屋外日射あり）
  return Math.round((0.735*t)+(0.0374*h)+(0.00292*t*h)+(7.619)-(4.557*(t**2)/1000)-(0.0572*h)-4.064);
}
function wbgtLevel(w){
  if(w<21) return{cls:'wbgt-safe',label:'ほぼ安全'};
  if(w<25) return{cls:'wbgt-safe',label:'注意'};
  if(w<28) return{cls:'wbgt-caution',label:'⚠️ 警戒'};
  if(w<31) return{cls:'wbgt-warning',label:'🔴 厳重警戒'};
  return{cls:'wbgt-danger',label:'🚨 危険'};
}

async function fetchWeather(){
  document.getElementById('wx-location').textContent=SITE_NAME;
  document.getElementById('wx-update').textContent='取得中…';
  try{
    const url=`https://api.open-meteo.com/v1/forecast?latitude=${SITE_LAT}&longitude=${SITE_LON}&current=temperature_2m,relative_humidity_2m,weathercode,apparent_temperature&hourly=temperature_2m,relative_humidity_2m&timezone=Asia%2FTokyo&forecast_days=1`;
    const res=await fetch(url);
    const json=await res.json();
    const c=json.current;
    const temp=c.temperature_2m;
    const hum=c.relative_humidity_2m;
    const code=c.weathercode;
    const wbgt=wbgtFromTempHum(temp,hum);
    const lv=wbgtLevel(wbgt);
    wxData={temp,hum,code,wbgt,lv};

    document.getElementById('wx-temp').textContent=`${temp}℃`;
    document.getElementById('wx-hum').textContent=`${hum}%`;
    document.getElementById('wx-weather').textContent=WX_CODES[code]||'—';
    document.getElementById('wx-wbgt-val').textContent=`${wbgt}℃`;
    const badge=document.getElementById('wx-wbgt-badge');
    badge.textContent=lv.label;badge.className=`wbgt-badge ${lv.cls}`;
    const now=new Date();
    document.getElementById('wx-update').textContent=`最終更新: ${p2(now.getHours())}:${p2(now.getMinutes())}`;

    // 熱中症カードのステータスを自動更新
    updateHeatCard(temp,wbgt,lv);
    // 熱中症セクションデータを自動更新
    updateHeatSection(temp,hum,wbgt,lv,WX_CODES[code]||'—');
    // アラート通知
    autoAlerts();
  }catch(e){
    document.getElementById('wx-update').textContent='取得失敗（ネットワーク確認）';
  }
}

function updateHeatCard(temp,wbgt,lv){
  const card=appData.cards.find(c=>c.id==='heat');
  if(!card) return;
  card.status=`気温:${temp}℃ / WBGT:${wbgt}℃ ${lv.label}`;
  card.statusColor=wbgt>=31?'danger':wbgt>=28?'warn':'ok';
  saveData();renderCards();
}

function updateHeatSection(temp,hum,wbgt,lv,wxStr){
  const sec=appData.sections['heat'];
  if(!sec) return;
  sec.rows[0][1]=`${temp}℃ （${wxStr}）`;
  sec.rows[1][1]=`${wbgt}℃ ${lv.label}\n（25未満:安全 / 25-28:注意 / 28-31:警戒 / 31以上:危険）`;
  saveData();
}

/* =====================================================
   AUTO ALERTS — 校正・資格期限チェック
   ===================================================== */
function autoAlerts(){
  const today=new Date();today.setHours(0,0,0,0);
  const alerts=[];

  // 校正期限
  (appData.sections['calibration']?.rows||[]).forEach(row=>{
    const name=row[0],dateStr=row[2],badge=row[3]||'';
    const d=parseDate(dateStr);if(!d) return;
    const diff=Math.floor((d-today)/(1000*60*60*24));
    if(diff<0) alerts.push(`🔴 【校正期限切れ】${name}（期限: ${dateStr}）`);
    else if(diff<=30) alerts.push(`🟠 【校正期限30日以内】${name}（あと${diff}日 / ${dateStr}）`);
  });

  // 資格期限
  (appData.sections['license']?.rows||[]).forEach(row=>{
    const name=row[0],skill=row[1],dateStr=row[3];
    const d=parseDate(dateStr);if(!d) return;
    const diff=Math.floor((d-today)/(1000*60*60*24));
    if(diff<0) alerts.push(`🔴 【資格期限切れ】${name}：${skill}（期限: ${dateStr}）`);
    else if(diff<=60) alerts.push(`🟠 【資格更新60日以内】${name}：${skill}（あと${diff}日）`);
  });

  // WBGT警告
  if(wxData&&wxData.wbgt>=28) alerts.push(`🌡️ 【熱中症警戒】現在のWBGT:${wxData.wbgt}℃ — 水分補給・休憩を徹底してください`);

  // 既存の自動アラート行を消して再追加
  appData.notices=appData.notices.filter(n=>!n.startsWith('🔴')&&!n.startsWith('🟠')&&!n.startsWith('🌡️'));
  appData.notices=[...alerts,...appData.notices];
  saveData();renderNotices();

  // 朝礼担当を自動更新
  updateMorningDuty();
}

function parseDate(str){
  if(!str||str.includes('無期限')||str.includes('自動')) return null;
  const m=str.match(/(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})/);
  if(!m) return null;
  return new Date(Number(m[1]),Number(m[2])-1,Number(m[3]));
}

/* =====================================================
   ROTATION — 朝礼担当自動計算
   ===================================================== */
function getTodayDuty(){
  const members=appData.rotation?.members||[];
  if(!members.length) return '（未設定）';
  const start=parseDate(appData.rotation?.startDate)||new Date('2025/07/07');
  const today=new Date();today.setHours(0,0,0,0);
  const days=Math.floor((today-start)/(1000*60*60*24));
  const idx=((days%members.length)+members.length)%members.length;
  return members[idx];
}
function getNextDuty(){
  const members=appData.rotation?.members||[];
  if(!members.length) return '（未設定）';
  const start=parseDate(appData.rotation?.startDate)||new Date('2025/07/07');
  const today=new Date();today.setHours(0,0,0,0);
  const days=Math.floor((today-start)/(1000*60*60*24))+1;
  const idx=((days%members.length)+members.length)%members.length;
  return members[idx];
}

function updateMorningDuty(){
  const duty=getTodayDuty();
  const next=getNextDuty();
  // カードステータス更新
  const card=appData.cards.find(c=>c.id==='morning');
  if(card){card.status=`本日担当：${duty}`;saveData();renderCards();}
  // セクションデータ更新
  const sec=appData.sections['morning'];
  if(sec){
    if(sec.rows[0]) sec.rows[0][1]=duty;
    if(sec.rows[sec.rows.length-1]&&sec.rows[sec.rows.length-1][0]==='次回朝礼担当') sec.rows[sec.rows.length-1][1]=next;
    saveData();
  }
}

