<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>鐵建 現場ポータル</title>
<style>
:root{
  --brand-dark:#0d47a1;--brand-mid:#1976d2;--brand-accent:#2196f3;--brand-hover:#1565c0;
  --bg-page:#f4f6f9;--bg-card:#fff;--bg-notice:#fff8e1;
  --text-main:#222;--text-sub:#555;--white:#fff;
  --radius:10px;--shadow:0 5px 10px rgba(0,0,0,.15);--font:"Yu Gothic","游ゴシック",sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg-page);color:var(--text-main);font-family:var(--font);min-height:100vh;display:flex;flex-direction:column;}

/* HEADER */
header{background:var(--brand-dark);color:var(--white);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;border-bottom:4px solid var(--brand-accent);}
.hdr-left h1{font-size:22px;font-weight:800;letter-spacing:.04em;}
.hdr-left p{font-size:12px;color:#b0bcd4;margin-top:2px;}
.hdr-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.hdr-info{text-align:right;font-size:12px;color:#b0bcd4;}
.hdr-date{font-size:14px;color:#90caf9;font-weight:700;}
.hdr-btns{display:flex;gap:8px;flex-wrap:wrap;}
.hdr-btn{padding:7px 13px;border:none;border-radius:6px;cursor:pointer;font-size:12px;font-weight:700;font-family:var(--font);}
#edit-toggle{background:#ff6d00;color:#fff;}
#edit-toggle.on{background:#43a047;}
#lang-btn{background:#7b1fa2;color:#fff;}
#translate-btn{background:#00838f;color:#fff;display:none;}
#reorder-btn{background:#00695c;color:#fff;display:none;}

/* LANG BAR */
#lang-bar{display:none;background:#4a148c;padding:8px 24px;gap:8px;flex-wrap:wrap;align-items:center;}
#lang-bar.show{display:flex;}
#lang-bar span{color:#ce93d8;font-size:12px;font-weight:700;margin-right:4px;}
.lang-pill{padding:5px 14px;border:2px solid #ce93d8;border-radius:20px;color:#fff;background:transparent;cursor:pointer;font-size:12px;font-family:var(--font);transition:.2s;}
.lang-pill.active,.lang-pill:hover{background:#7b1fa2;border-color:#fff;}
#translate-status{font-size:11px;color:#ce93d8;margin-left:8px;}

/* WEATHER BAR */
#weather-bar{background:linear-gradient(90deg,#0277bd,#0288d1);color:#fff;padding:10px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;font-size:13px;}
.wx-item{display:flex;align-items:center;gap:6px;}
.wx-label{color:#b3e5fc;font-size:11px;}
.wx-val{font-weight:700;font-size:15px;}
.wbgt-badge{padding:2px 10px;border-radius:20px;font-size:12px;font-weight:700;}
.wbgt-safe{background:#1b5e20;}.wbgt-caution{background:#e65100;}.wbgt-warning{background:#b71c1c;}.wbgt-danger{background:#880e4f;}
#wx-update{font-size:11px;color:#b3e5fc;margin-left:auto;}
#wx-refresh{background:none;border:1px solid #b3e5fc;color:#b3e5fc;border-radius:4px;padding:3px 8px;cursor:pointer;font-size:11px;font-family:var(--font);}

/* CONTAINER */
.container{width:95%;max-width:1280px;margin:20px auto;flex:1;}

/* NOTICE */
.notice{background:var(--bg-notice);border-left:6px solid orange;border-radius:var(--radius);padding:14px 18px;margin-bottom:20px;box-shadow:var(--shadow);}
.notice-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.notice-hdr h2{font-size:14px;color:var(--brand-dark);}
#notice-list{list-style:none;display:flex;flex-direction:column;gap:5px;}
#notice-list li{font-size:13px;padding-left:16px;position:relative;display:flex;align-items:flex-start;gap:6px;}
#notice-list li::before{content:"▶";position:absolute;left:0;font-size:9px;color:var(--brand-accent);top:4px;}
#notice-list li.auto-alert::before{color:#e53935;}
.notice-text{flex:1;}
.del-btn{background:none;border:none;color:#e53935;cursor:pointer;font-size:15px;line-height:1;padding:0 2px;display:none;}
.edit-mode .del-btn{display:inline;}
.add-notice-row{display:none;margin-top:8px;gap:8px;}
.edit-mode .add-notice-row{display:flex;}
.add-notice-row input{flex:1;padding:6px 10px;border:1px solid #ccc;border-radius:6px;font-family:var(--font);font-size:13px;}
.add-notice-row button{padding:6px 12px;background:var(--brand-accent);color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:var(--font);font-weight:700;}

/* SECTION LABEL */
.section-label{font-size:12px;font-weight:700;color:var(--text-sub);margin-bottom:12px;border-left:3px solid var(--brand-accent);padding-left:8px;}

/* GRID */
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}

/* CARD */
.card{background:var(--bg-card);border-radius:var(--radius);box-shadow:var(--shadow);transition:transform .25s,box-shadow .25s;cursor:pointer;overflow:hidden;display:flex;flex-direction:column;position:relative;}
.card:hover{transform:translateY(-4px);box-shadow:0 10px 22px rgba(0,0,0,.18);}
.card-head{background:var(--brand-mid);color:var(--white);padding:12px 14px;display:flex;align-items:center;gap:8px;}
.card-head .icon{font-size:18px;line-height:1;}
.card-head h2{font-size:15px;font-weight:700;}
.card-body{padding:12px 14px;flex:1;font-size:13px;color:var(--text-sub);}
.card-body ul{list-style:none;display:flex;flex-direction:column;gap:4px;}
.card-body ul li{padding-left:12px;position:relative;line-height:1.5;}
.card-body ul li::before{content:"–";position:absolute;left:0;color:var(--brand-accent);font-weight:700;}
.card-foot{padding:0 14px 14px;display:flex;flex-direction:column;gap:6px;}
.card-status{font-size:11px;color:var(--text-sub);display:flex;align-items:center;gap:4px;}
.dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0;}
.dot-ok{background:#43a047;}.dot-warn{background:#fb8c00;}.dot-danger{background:#e53935;}
.btn{display:block;width:100%;padding:9px;background:var(--brand-accent);color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:700;font-family:var(--font);transition:background .2s;}
.btn:hover{background:var(--brand-hover);}
.card-edit-btn{display:none;position:absolute;top:7px;right:7px;background:rgba(255,255,255,.22);border:none;border-radius:4px;color:#fff;cursor:pointer;font-size:11px;padding:2px 7px;font-family:var(--font);}
.edit-mode .card-edit-btn{display:block;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center;}
.modal-overlay.active{display:flex;}
.modal{background:#fff;border-radius:var(--radius);max-width:740px;width:94%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 50px rgba(0,0,0,.3);animation:fadeUp .2s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.modal-head{background:var(--brand-mid);color:#fff;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;border-radius:var(--radius) var(--radius) 0 0;position:sticky;top:0;z-index:2;}
.modal-head h3{font-size:16px;font-weight:700;}
.modal-head-btns{display:flex;align-items:center;gap:8px;}
.modal-close{background:none;border:none;color:#b0d4ff;font-size:20px;cursor:pointer;line-height:1;padding:2px 6px;}
.modal-close:hover{color:#fff;}
.modal-body{padding:20px;}
.modal-desc{font-size:13px;color:var(--text-sub);margin-bottom:14px;line-height:1.7;border-radius:4px;padding:2px;}

/* TABLE */
.modal-table{width:100%;border-collapse:collapse;font-size:13px;margin-top:6px;}
.modal-table th,.modal-table td{padding:8px 10px;border-bottom:1px solid #e0e5f0;text-align:left;vertical-align:top;}
.modal-table th{background:#f0f3fa;font-weight:700;color:var(--brand-dark);}
.modal-table td input,.modal-table td textarea,.modal-table td select{width:100%;padding:4px 6px;border:1px solid #bbb;border-radius:4px;font-family:var(--font);font-size:12px;}
.modal-table td textarea{resize:vertical;min-height:36px;}

/* BADGE */
.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;}
.badge-ok{background:#e8f5e9;color:#2e7d32;}.badge-warn{background:#fff3e0;color:#e65100;}.badge-danger{background:#ffebee;color:#c62828;}

/* TABLE CONTROLS */
.row-del{background:none;border:none;color:#e53935;cursor:pointer;font-size:16px;line-height:1;padding:0 3px;}
.add-row-btn{margin-top:10px;padding:7px 14px;background:#e3f2fd;color:var(--brand-dark);border:1px solid var(--brand-accent);border-radius:6px;cursor:pointer;font-family:var(--font);font-weight:700;font-size:12px;}
.save-btn{margin-top:12px;padding:9px;background:#43a047;color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:var(--font);font-weight:700;font-size:13px;width:100%;}
.save-btn:hover{background:#2e7d32;}
.danger-btn{padding:9px;background:#e53935;color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:var(--font);font-weight:700;font-size:13px;flex:1;}
.danger-btn:hover{background:#c62828;}

/* CARD EDIT FORM */
#card-edit-modal .modal{max-width:460px;}
.form-group{margin-bottom:12px;}
.form-group label{display:block;font-size:12px;font-weight:700;color:var(--brand-dark);margin-bottom:4px;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:7px 9px;border:1px solid #ccc;border-radius:6px;font-family:var(--font);font-size:13px;}
.bullet-list{display:flex;flex-direction:column;gap:5px;margin-bottom:6px;}
.bullet-row{display:flex;gap:5px;align-items:center;}
.bullet-row input{flex:1;padding:5px 7px;border:1px solid #ccc;border-radius:4px;font-family:var(--font);font-size:12px;}

/* REORDER MODAL */
#reorder-modal .modal{max-width:480px;}
.reorder-hint{font-size:12px;color:var(--text-sub);margin-bottom:12px;line-height:1.6;}
#reorder-list{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.reorder-row{display:flex;align-items:center;gap:10px;background:#f5f7fb;border:1px solid #e0e5f0;border-radius:8px;padding:8px 10px;cursor:grab;transition:background .15s;}
.reorder-row.dragging{opacity:.4;}
.reorder-row:hover{background:#eef2fa;}
.reorder-handle{color:#aab2c5;font-size:14px;flex-shrink:0;}
.reorder-icon{font-size:17px;flex-shrink:0;}
.reorder-title{flex:1;font-size:13px;color:var(--text-main);font-weight:700;}
.reorder-btns{display:flex;gap:4px;flex-shrink:0;}
.reorder-btns button{background:#fff;border:1px solid #ccc;border-radius:5px;width:26px;height:26px;font-size:12px;cursor:pointer;color:var(--brand-dark);}
.reorder-btns button:hover:not(:disabled){background:var(--brand-accent);color:#fff;border-color:var(--brand-accent);}
.reorder-btns button:disabled{opacity:.3;cursor:not-allowed;}

/* IMAGE UPLOAD */
.img-upload-area{border:2px dashed #90caf9;border-radius:8px;padding:16px;text-align:center;cursor:pointer;color:var(--text-sub);font-size:13px;margin-top:10px;}
.img-upload-area:hover{border-color:var(--brand-accent);}
.img-preview-list{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
.img-thumb-wrap{position:relative;}
.img-thumb-wrap img{width:80px;height:62px;object-fit:cover;border-radius:6px;border:1px solid #ddd;cursor:pointer;}
.img-thumb-del{position:absolute;top:-5px;right:-5px;background:#e53935;color:#fff;border:none;border-radius:50%;width:16px;height:16px;font-size:11px;cursor:pointer;line-height:16px;text-align:center;padding:0;}

/* ROTATION MODAL */
#rotation-modal .modal{max-width:500px;}
.rotation-member{display:flex;gap:6px;align-items:center;margin-bottom:6px;}
.rotation-member input{flex:1;padding:6px 8px;border:1px solid #ccc;border-radius:4px;font-family:var(--font);font-size:13px;}

/* TRANSLATE MODAL */
#trans-modal .modal{max-width:640px;}
.trans-area{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px;}
.trans-box{display:flex;flex-direction:column;gap:6px;}
.trans-box label{font-size:12px;font-weight:700;color:var(--brand-dark);}
.trans-box textarea{padding:8px;border:1px solid #ccc;border-radius:6px;font-family:var(--font);font-size:13px;resize:vertical;min-height:120px;}
.trans-lang-sel{padding:6px 8px;border:1px solid #ccc;border-radius:6px;font-family:var(--font);font-size:13px;background:#fff;}
.trans-btn{padding:9px;background:var(--brand-accent);color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:var(--font);font-weight:700;font-size:13px;width:100%;margin-top:10px;}
.trans-btn:hover{background:var(--brand-hover);}
.trans-notice{font-size:11px;color:var(--text-sub);margin-top:6px;text-align:center;}

/* FOOTER */
footer{text-align:center;padding:16px;font-size:11px;color:var(--text-sub);border-top:1px solid #dde1ec;margin-top:14px;}

/* RESPONSIVE */
@media(max-width:960px){.grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.grid{grid-template-columns:1fr;}header{padding:12px 14px;}.hdr-left h1{font-size:17px;}.trans-area{grid-template-columns:1fr;}}
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="hdr-left">
    <h1>🏭 鐵建　現場ポータルシステム</h1>
    <p>教育・安全・品質管理を一つに。</p>
  </div>
  <div class="hdr-right">
    <div class="hdr-info">
      <div class="hdr-date" id="js-date"></div>
      <div id="js-time"></div>
      <div id="js-user" style="margin-top:2px;">👤 管理者</div>
    </div>
    <div class="hdr-btns">
      <button class="hdr-btn" id="lang-btn" onclick="toggleLangBar()">🌐 言語</button>
      <button class="hdr-btn" id="translate-btn" onclick="openModal('trans-modal')">✍️ 翻訳</button>
      <button class="hdr-btn" id="reorder-btn" onclick="openReorderModal()">📐 メニュー並び替え</button>
      <button class="hdr-btn" id="edit-toggle" onclick="toggleEditMode()">✏️ 編集</button>
    </div>
  </div>
</header>

<!-- LANG BAR -->
<div id="lang-bar">
  <span>表示言語：</span>
  <button class="lang-pill active" onclick="setLang('ja')">🇯🇵 日本語</button>
  <button class="lang-pill" onclick="setLang('vi')">🇻🇳 Tiếng Việt</button>
  <button class="lang-pill" onclick="setLang('pt')">🇧🇷 Português</button>
  <button class="lang-pill" onclick="setLang('my')">🇲🇲 မြန်မာ</button>
  <span id="translate-status"></span>
</div>

<!-- WEATHER BAR -->
<div id="weather-bar">
  <div class="wx-item">
    <span class="wx-label">📍 現在地</span>
    <span class="wx-val" id="wx-location">取得中…</span>
  </div>
  <div class="wx-item">
    <span class="wx-label">🌡️ 気温</span>
    <span class="wx-val" id="wx-temp">—</span>
  </div>
  <div class="wx-item">
    <span class="wx-label">💧 湿度</span>
    <span class="wx-val" id="wx-hum">—</span>
  </div>
  <div class="wx-item">
    <span class="wx-label">🌤️ 天気</span>
    <span class="wx-val" id="wx-weather">—</span>
  </div>
  <div class="wx-item">
    <span class="wx-label">⚠️ WBGT目安</span>
    <span class="wx-val"><span id="wx-wbgt-val">—</span> <span class="wbgt-badge" id="wx-wbgt-badge"></span></span>
  </div>
  <span id="wx-update"></span>
  <button id="wx-refresh" onclick="fetchWeather()">↻ 更新</button>
</div>

<!-- MAIN -->
<div class="container">

  <!-- お知らせ -->
  <div class="notice">
    <div class="notice-hdr">
      <h2 id="notice-title">📢 本日のお知らせ</h2>
    </div>
    <ul id="notice-list"></ul>
    <div class="add-notice-row">
      <input type="text" id="new-notice-input" placeholder="新しいお知らせを入力…">
      <button onclick="addNotice()">＋ 追加</button>
    </div>
  </div>

  <div class="section-label" id="menu-label">各種機能メニュー</div>
  <div class="grid" id="card-grid"></div>
</div>

<footer>© 2025 鐵建株式会社　現場ポータルシステム — 安全第一</footer>

<!-- ===== MODALS ===== -->

<!-- カード編集 -->
<div class="modal-overlay" id="card-edit-modal">
  <div class="modal">
    <div class="modal-head">
      <h3>✏️ カードを編集</h3>
      <button class="modal-close" onclick="closeModal('card-edit-modal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-card-id">
      <div class="form-group"><label>アイコン（絵文字）</label><input type="text" id="edit-icon" maxlength="4"></div>
      <div class="form-group"><label>タイトル</label><input type="text" id="edit-title"></div>
      <div class="form-group">
        <label>説明（各行1項目）</label>
        <div class="bullet-list" id="edit-bullets"></div>
        <button class="add-row-btn" onclick="addBulletRow('')">＋ 項目追加</button>
      </div>
      <div class="form-group"><label>ステータス表示</label><input type="text" id="edit-status"></div>
      <div class="form-group"><label>ステータス色</label>
        <select id="edit-status-color">
          <option value="ok">緑（正常）</option>
          <option value="warn">オレンジ（注意）</option>
          <option value="danger">赤（危険）</option>
        </select>
      </div>
      <button class="save-btn" onclick="saveCardEdit()">💾 保存</button>
    </div>
  </div>
</div>

<!-- セクション詳細 -->
<div class="modal-overlay" id="section-modal">
  <div class="modal">
    <div class="modal-head">
      <h3 id="section-modal-title"></h3>
      <div class="modal-head-btns">
        <span id="section-translate-status" style="font-size:11px;color:#b0d4ff;"></span>
        <button class="modal-close" onclick="closeModal('section-modal')">✕</button>
      </div>
    </div>
    <div class="modal-body" id="section-modal-body"></div>
  </div>
</div>

<!-- 朝礼ローテーション設定 -->
<div class="modal-overlay" id="rotation-modal">
  <div class="modal">
    <div class="modal-head">
      <h3>👷 朝礼担当ローテーション設定</h3>
      <button class="modal-close" onclick="closeModal('rotation-modal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:13px;color:var(--text-sub);margin-bottom:14px;">メンバーリストを登録すると、曜日順に自動でローテーションします。</p>
      <div id="rotation-members"></div>
      <button class="add-row-btn" onclick="addRotationMember()">＋ メンバー追加</button>
      <button class="save-btn" onclick="saveRotation()">💾 保存してローテーション更新</button>
    </div>
  </div>
</div>

<!-- 翻訳モーダル -->
<div class="modal-overlay" id="trans-modal">
  <div class="modal">
    <div class="modal-head">
      <h3>✍️ テキスト翻訳</h3>
      <button class="modal-close" onclick="closeModal('trans-modal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:13px;color:var(--text-sub);">日本語から各言語へ翻訳します（MyMemory無料APIを使用）。</p>
      <div class="trans-area">
        <div class="trans-box">
          <label>🇯🇵 日本語（原文）</label>
          <textarea id="trans-src" placeholder="ここに日本語を入力…"></textarea>
        </div>
        <div class="trans-box">
          <label>翻訳先言語</label>
          <select class="trans-lang-sel" id="trans-lang-sel">
            <option value="vi">🇻🇳 ベトナム語</option>
            <option value="pt">🇧🇷 ポルトガル語</option>
            <option value="my">🇲🇲 ミャンマー語</option>
            <option value="en">🇺🇸 英語</option>
          </select>
          <textarea id="trans-dst" placeholder="翻訳結果がここに表示されます…" readonly style="margin-top:8px;background:#f9f9f9;"></textarea>
        </div>
      </div>
      <button class="trans-btn" onclick="doTranslate()">🌐 翻訳する</button>
      <p class="trans-notice">※ MyMemory無料APIを使用（1日約1000文字まで）。長文はGoogle翻訳をご利用ください。</p>
      <button class="add-row-btn" style="margin-top:8px;width:100%;text-align:center;" onclick="openGoogleTranslate()">🔗 Google翻訳で開く</button>
    </div>
  </div>
</div>

<!-- メニュー並び替え -->
<div class="modal-overlay" id="reorder-modal">
  <div class="modal">
    <div class="modal-head">
      <h3>📐 機能メニューの並び替え</h3>
      <button class="modal-close" onclick="closeModal('reorder-modal')">✕</button>
    </div>
    <div class="modal-body">
      <p class="reorder-hint">▲▼ボタンで順番を入れ替えられます（PCではドラッグでも移動できます）。並び終えたら「保存」を押してください。</p>
      <div id="reorder-list"></div>
      <button class="save-btn" onclick="saveReorder()">💾 この順番で保存</button>
    </div>
  </div>
