function buildTable(id){
  const sec=appData.sections[id];
  const th=sec.cols.map(c=>`<th>${escH(c)}</th>`).join('')+'<th style="width:32px;"></th>';
  const tbody=sec.rows.map((row,ri)=>{
    const cells=row.map((cell,ci)=>{
      const type=sec.colTypes[ci];
      if(type==='badge'){
        const[cls,label]=(cell||'ok:').split(':');
        const sel=['ok','warn','danger'].map(v=>`<option value="${v}"${v===cls?' selected':''}>${v==='ok'?'緑':v==='warn'?'橙':'赤'}</option>`).join('');
        return `<td><select data-row="${ri}" data-col="${ci}" class="bs">${sel}</select>
          <input type="text" data-row="${ri}" data-col="${ci}" data-bl="1" value="${escA(label||'')}" placeholder="ラベル" style="margin-top:3px;"></td>`;
      }else if(type==='textarea'){
        return `<td><textarea data-row="${ri}" data-col="${ci}">${escH(cell)}</textarea></td>`;
      }
      return `<td><input type="text" data-row="${ri}" data-col="${ci}" value="${escA(cell)}"></td>`;
    }).join('');
    return `<tr>${cells}<td><button class="row-del" onclick="delRow('${id}',${ri})">✕</button></td></tr>`;
  }).join('');
  return `<table class="modal-table"><thead><tr>${th}</tr></thead><tbody id="tb-${id}">${tbody}</tbody></table>`;
}

