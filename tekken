function renderReorderList(){
  const list=document.getElementById('reorder-list');
  list.innerHTML='';
  reorderWorking.forEach((id,idx)=>{
    const card=appData.cards.find(c=>c.id===id);
    if(!card) return;
    const row=document.createElement('div');
    row.className='reorder-row';
    row.draggable=true;
    row.innerHTML=`
      <span class="reorder-handle">⠿</span>
      <span class="reorder-icon">${card.icon}</span>
      <span class="reorder-title">${escH(card.title)}</span>
      <div class="reorder-btns">
        <button ${idx===0?'disabled':''} onclick="moveReorder(${idx},-1)">▲</button>
        <button ${idx===reorderWorking.length-1?'disabled':''} onclick="moveReorder(${idx},1)">▼</button>
      </div>`;
    row.addEventListener('dragstart',e=>{e.dataTransfer.setData('text/plain',String(idx));row.classList.add('dragging');});
    row.addEventListener('dragend',()=>row.classList.remove('dragging'));
    row.addEventListener('dragover',e=>e.preventDefault());
    row.addEventListener('drop',e=>{
      e.preventDefault();
      const fromIdx=Number(e.dataTransfer.getData('text/plain'));
      if(Number.isNaN(fromIdx)||fromIdx===idx) return;
      const[moved]=reorderWorking.splice(fromIdx,1);
      reorderWorking.splice(idx,0,moved);
      renderReorderList();
    });
    list.appendChild(row);
  });
}

function moveReorder(idx,dir){
  const newIdx=idx+dir;
  if(newIdx<0||newIdx>=reorderWorking.length) return;
  [reorderWorking[idx],reorderWorking[newIdx]]=[reorderWorking[newIdx],reorderWorking[idx]];
  renderReorderList();
}

function saveReorder(){
  const newCards=reorderWorking.map(id=>appData.cards.find(c=>c.id===id)).filter(Boolean);
  appData.cards=newCards;
  saveData();renderCards();closeModal('reorder-modal');
  alert('✅ 並び順を保存しました');
}

