    empty.textContent='まだ投稿がありません。最初の投稿をしてみましょう！';
    container.appendChild(empty);
    return;
  }

  const reacted=loadReacted();
  appData.board.forEach(post=>{
    const card=document.createElement('div');
    card.style='background:#fff;border:1px solid #e0e5f0;border-radius:10px;padding:12px 14px;margin-bottom:10px;';
    const myReacts=reacted[post.id]||[];
    const reactBtn=(type,emoji,label)=>{
      const active=myReacts.includes(type);
      const cnt=(post.reactions&&post.reactions[type])||0;
      return `<button onclick="reactPost('${post.id}','${type}')" style="border:1px solid ${active?'var(--brand-accent)':'#ddd'};background:${active?'#e3f2fd':'#fff'};border-radius:20px;padding:4px 10px;font-size:12px;cursor:pointer;font-family:var(--font);margin-right:6px;">${emoji} ${label} ${cnt}</button>`;
    };
    const delBtn=isEditMode?`<button class="del-btn" style="display:inline;" onclick="deleteBoardPost('${post.id}')">✕</button>`:'';
    card.innerHTML=`
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
        <div style="font-size:13px;font-weight:700;color:var(--brand-dark);">👤 ${escH(post.author)}</div>
        <div style="font-size:11px;color:var(--text-sub);display:flex;align-items:center;gap:4px;">${escH(post.time)}${delBtn}</div>
      </div>
      <div style="font-size:13px;color:var(--text-main);line-height:1.6;white-space:pre-wrap;margin-bottom:8px;">${escH(post.text)}</div>
      ${post.image?`<img src="${post.image}" style="max-width:220px;max-height:170px;border-radius:8px;border:1px solid #ddd;margin-bottom:8px;display:block;cursor:pointer;" onclick="window.open('${post.image}','_blank')">`:''}
      <div>${reactBtn('smile','😊','いいね')}${reactBtn('thanks','🙏','助かった')}${reactBtn('nice','👏','ナイス')}</div>
    `;
    container.appendChild(card);
  });
}

function reactPost(postId,type){
  const post=appData.board.find(p=>p.id===postId);if(!post) return;
  if(!post.reactions) post.reactions={smile:0,thanks:0,nice:0};
  const reacted=loadReacted();
  if(!reacted[postId]) reacted[postId]=[];
  const idx=reacted[postId].indexOf(type);
  if(idx>=0){
    reacted[postId].splice(idx,1);
    post.reactions[type]=Math.max(0,(post.reactions[type]||0)-1);
  }else{
    reacted[postId].push(type);
    post.reactions[type]=(post.reactions[type]||0)+1;
  }
  saveReacted(reacted);saveData();openSection('board');
}

function deleteBoardPost(id){
  showConfirm('この投稿を削除しますか？',()=>{
    appData.board=appData.board.filter(p=>p.id!==id);
    updateBoardCardStatus();saveData();openSection('board');
  });
}

/* =====================================================
   IMAGES
   ===================================================== */
function handleFiles(id,files){
  const sec=appData.sections[id];if(!sec.images) sec.images=[];
  Array.from(files).forEach(file=>{
    const reader=new FileReader();
    reader.onload=e=>{sec.images.push({name:file.name,data:e.target.result,type:file.type});saveData();renderImages(id);};
    reader.readAsDataURL(file);
  });
}
function renderImages(id){
  const sec=appData.sections[id];
  const list=document.getElementById(`ip-${id}`);if(!list) return;
  list.innerHTML='';
  (sec.images||[]).forEach((img,i)=>{
    const w=document.createElement('div');w.className='img-thumb-wrap';
    if(img.type==='application/pdf'){
      w.innerHTML=`<div style="width:80px;height:62px;background:#f5f5f5;border:1px solid #ddd;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;color:#555;text-align:center;padding:3px;">📄<br>${escH(img.name)}</div>
        <button class="img-thumb-del" onclick="delImg('${id}',${i})">✕</button>`;
    }else{
      w.innerHTML=`<img src="${img.data}" title="${escA(img.name)}">
        <button class="img-thumb-del" onclick="delImg('${id}',${i})">✕</button>`;
      w.querySelector('img').onclick=()=>window.open(img.data,'_blank');
    }
    list.appendChild(w);
  });
}
function delImg(id,i){
  showConfirm('この画像を削除しますか？',()=>{
    appData.sections[id].images.splice(i,1);saveData();renderImages(id);
  });
}

/* =====================================================
   EDIT MODE
   ===================================================== */
function toggleEditMode(){
  isEditMode=!isEditMode;
  document.body.classList.toggle('edit-mode',isEditMode);
  const L=I18N[currentLang]||I18N.ja;
  const btn=document.getElementById('edit-toggle');
  btn.textContent=isEditMode?L.editEnd:L.editMode;
  btn.classList.toggle('on',isEditMode);
  document.getElementById('translate-btn').style.display=isEditMode?'block':'none';
  document.getElementById('reorder-btn').style.display=isEditMode?'block':'none';
}

/* =====================================================
   MODAL
   ===================================================== */
function openModal(id){document.getElementById(id).classList.add('active');}
function closeModal(id){document.getElementById(id).classList.remove('active');}
document.querySelectorAll('.modal-overlay').forEach(ov=>{
  ov.addEventListener('click',e=>{if(e.target===ov) ov.classList.remove('active');});
});
document.addEventListener('keydown',e=>{
  if(e.key==='Escape') document.querySelectorAll('.modal-overlay.active').forEach(el=>el.classList.remove('active'));
});

/* 確認ダイアログ（window.confirmはサンドボックス環境等でブロックされる場合があるため、独自UIで代替） */
let _confirmCallback=null;
function showConfirm(message,onConfirm){
  document.getElementById('confirm-message').textContent=message;
  _confirmCallback=onConfirm;
  openModal('confirm-modal');
}
document.getElementById('confirm-ok-btn').addEventListener('click',()=>{
  closeModal('confirm-modal');
  const cb=_confirmCallback;_confirmCallback=null;
  if(cb) cb();
});

/* =====================================================
   UTILS
   ===================================================== */
function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function escA(s){return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;');}

/* =====================================================
   INIT
   ===================================================== */
renderNotices();
renderCards();
fetchWeather();
setInterval(fetchWeather,60*60*1000); // 1時間ごとに自動更新
setTimeout(()=>{updateMorningDuty();autoAlerts();},1000);
</script>
</body>
